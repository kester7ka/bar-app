# Пример переменных окружения для бэкенда.
# Скопируй в .env (рядом с этим файлом). .env в git не попадает.
# Загружать .env можно через python-dotenv (pip install python-dotenv)
# или просто прописать переменные через окружение системы / systemd unit.

# --- CORS ---
# '*' разрешает любой источник — нормально для локальной разработки.
# Для продакшена перечисли через запятую конкретные домены:
# BAR_APP_CORS_ORIGINS=https://bar.example.com,https://admin.example.com
BAR_APP_CORS_ORIGINS=*

# --- Хост и порт сервера (если будешь дёргать gunicorn/uwsgi через переменные) ---
# HOST=127.0.0.1
# PORT=5000

# --- Админ-аккаунт ---
# При старте сервер создаст администратора с этими логином/паролем (если его ещё нет).
# Админ умеет переключаться между барами и генерировать ключи регистрации.
# Задай надёжный пароль и НЕ коммить .env.
BAR_APP_ADMIN_USER=admin
BAR_APP_ADMIN_PASSWORD=смени-на-надёжный-пароль
