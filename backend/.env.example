# Пример переменных окружения для бэкенда.
# Скопируй в .env (рядом с этим файлом). .env в git не попадает.
# Загружать .env можно через python-dotenv (pip install python-dotenv)
# или просто прописать переменные через окружение системы / systemd unit.

# --- CORS ---
# По умолчанию (если переменная не задана) разрешён только https://kester7ka.github.io.
# '*' разрешает любой источник — ТОЛЬКО для локальной разработки, в проде НЕ ставь.
# Для продакшена перечисли через запятую конкретные домены:
# BAR_APP_CORS_ORIGINS=https://kester7ka.github.io
BAR_APP_CORS_ORIGINS=https://kester7ka.github.io

# --- Лимит размера тела запроса ---
# Жёстко задан в коде: 2 МБ (MAX_CONTENT_LENGTH). Менять через переменную нельзя — правится в server.py.

# --- База знаний (оверрайды от админа) ---
# Путь к JSON с загруженными админом обновлениями. По умолчанию рядом с БД (на volume).
# BAR_APP_KB_PATH=/data/kb_overrides.json

# --- Путь к базе данных (Railway volume) ---
# BAR_APP_DB_PATH=/data/bar.db

# --- График смен (Яндекс.Диск) ---
# Публичная ссылка на xlsx-таблицу графика. Содержит ФИО, телефоны, выплаты —
# поэтому НЕ хранится в коде, только здесь/в переменных окружения.
# Без неё раздел «График» вернёт «не настроен», остальное работает.
# SCHEDULE_PUBLIC_KEY=https://disk.360.yandex.ru/d/XXXXXXXXXXXX

# --- Хост и порт сервера (если будешь дёргать gunicorn/uwsgi через переменные) ---
# HOST=127.0.0.1
# PORT=5000

# --- Админ-аккаунт ---
# При старте сервер создаст администратора с этими логином/паролем (если его ещё нет).
# Админ умеет переключаться между барами и генерировать ключи регистрации.
# Задай надёжный пароль и НЕ коммить .env.
BAR_APP_ADMIN_USER=admin
BAR_APP_ADMIN_PASSWORD=смени-на-надёжный-пароль

HONEST_MARK_URL=https://mobile.api.crpt.ru/mobile/check
